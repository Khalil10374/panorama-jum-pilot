APP_NAME="Panorama Jum"
APP_ENV=local
APP_URL=http://localhost:3000

API_URL=http://localhost:4000

SECRET_KEY=change-this-secret-key-before-production
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/panorama_jum
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# For same-Wi-Fi mobile access, open the URL printed by run-project.bat.
# The frontend proxies /api and /media through the same LAN address.

VITE_API_URL=/api
