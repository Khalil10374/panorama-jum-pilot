{
  "name": "panorama-jum-management",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "dev:api": "python -m uvicorn src.main:app --reload --host 0.0.0.0 --port 8000 --app-dir apps/api",
    "install:all": "npm --prefix apps/web install && python -m pip install -r apps/api/requirements.txt"
  }
}
